{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "dependencies",
    "supply-chain"
  ],
  "packageRules": [
    {
      "description": "Delay PyPI updates to reduce exposure to fresh malicious publishes.",
      "matchDatasources": [
        "pypi"
      ],
      "minimumReleaseAge": "3 days",
      "internalChecksFilter": "strict"
    },
    {
      "description": "Require focused review for sensitive runtime and packaging dependencies.",
      "matchPackageNames": [
        "uv-build",
        "databricks-job-runner",
        "databricks-sdk",
        "neo4j",
        "pydantic",
        "pydantic-settings"
      ],
      "addLabels": [
        "security-sensitive"
      ]
    }
  ]
}
