# Copy to docker-tests/.env (gitignored), then point the spike at it:
#
#   cp docker-tests/.env.example docker-tests/.env
#   export NEO4J_SPIKE_ENV_FILE="$(pwd)/docker-tests/.env"
#
# Both consumers read this one file:
#  - `docker compose` (run from docker-tests/) reads NEO4J_SPIKE_PASSWORD
#    for the container's NEO4J_AUTH.
#  - the spike reads NEO4J_URI/USERNAME/PASSWORD via NEO4J_SPIKE_ENV_FILE.
#
# These are throwaway localhost credentials for an ephemeral container, not
# secrets. The shared repo-root .env (real Neo4j) is never touched.

NEO4J_SPIKE_PASSWORD=testpassword12

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=testpassword12
