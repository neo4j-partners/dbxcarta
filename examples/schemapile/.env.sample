# SchemaPile example: local-only config for the standalone tooling.
# Copy to .env and fill the placeholders. The populated .env is local-only.
#
# This file holds exactly two things and nothing else:
#   - the NEO4J_* credentials for this integration's Neo4j instance, and
#   - the SCHEMAPILE_* knobs that only this example's dataset/question tooling
#     reads (upstream checkout, slice/candidate filters, generator params).
#
# Everything shared or per-integration lives elsewhere and must not be copied
# here (the one-key-one-file rule):
#   - shared infra (DATABRICKS_PROFILE, DATABRICKS_WAREHOUSE_ID, endpoints) is in
#     the repo-root base .env;
#   - per-integration config (DBXCARTA_CATALOG, DATABRICKS_VOLUME_PATH,
#     DATABRICKS_SECRET_SCOPE) is in the committed ./dbxcarta-overlay.env.
# The connected tools (question generator, context dump) load all three layers
# (overlay + base + this file).
#
# NEO4J_* are consumed two ways:
#   - setup_secrets.sh reads them to provision the Databricks secret scope named
#     in ./dbxcarta-overlay.env (pass --profile, since this file no longer sets
#     DATABRICKS_PROFILE);
#   - off-cluster, the generator/client read them straight from this file.

# =============================================================================
# 1. Upstream SchemaPile checkout
# Clone https://github.com/amsterdata/schemapile and follow its README to
# download schemapile-perm.json into that directory. Point SCHEMAPILE_REPO at
# that local checkout.
# =============================================================================
SCHEMAPILE_REPO=/path/to/your/schemapile/checkout
SCHEMAPILE_INPUT=schemapile-perm.json

# =============================================================================
# 2. Slice parameters. Passed verbatim to slice.py.
# =============================================================================
SCHEMAPILE_TARGET_TABLES=1000
SCHEMAPILE_STRATEGY=random
SCHEMAPILE_SEED=42
SCHEMAPILE_MIN_TABLES=2
SCHEMAPILE_MAX_TABLES=100
SCHEMAPILE_MIN_FK_EDGES=1
SCHEMAPILE_REQUIRE_SELF_CONTAINED=true
SCHEMAPILE_REQUIRE_DATA=false

# Local cache for the produced slice JSON.
SCHEMAPILE_SLICE_CACHE=.cache/slice_random_1000.json

# Committed blueprint: the candidate-table JSON the materializer and question
# generator both read. The select step regenerates it here; git is the source
# of truth.
SCHEMAPILE_CANDIDATE_CACHE=blueprint/candidates_random_1000.json

# =============================================================================
# 3. Candidate selector filters
# Applied on top of the slice. The candidate JSON is what both the
# materializer and the LLM question generator consume.
# =============================================================================
SCHEMAPILE_CANDIDATE_MIN_TABLES=3
SCHEMAPILE_CANDIDATE_MAX_TABLES=20
SCHEMAPILE_CANDIDATE_MIN_FK_EDGES=2
SCHEMAPILE_CANDIDATE_REQUIRE_DATA=false
SCHEMAPILE_CANDIDATE_LIMIT=20

# =============================================================================
# 4. Question generator (LLM via Databricks Foundation Model API)
# =============================================================================
SCHEMAPILE_QUESTION_MODEL=databricks-meta-llama-3-3-70b-instruct
SCHEMAPILE_QUESTIONS_PER_SCHEMA=6
SCHEMAPILE_QUESTION_TEMPERATURE=0.2

# =============================================================================
# 5. Neo4j secrets
# =============================================================================
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
