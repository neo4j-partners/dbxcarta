# dbxcarta SchemaPile example overlay.
# Copy this file to .env in the example directory and fill the placeholders.
# The populated .env is local-only and must not be committed.

# =============================================================================
# 1. Upstream SchemaPile checkout
# Clone https://github.com/amsterdata/schemapile and follow its README to
# download schemapile-perm.json into that directory. Point SCHEMAPILE_REPO at
# that local checkout.
# =============================================================================
SCHEMAPILE_REPO=/path/to/your/schemapile/checkout
SCHEMAPILE_INPUT=schemapile-perm.json

# =============================================================================
# 2. Slice parameters. Passed verbatim to slice.py.
# =============================================================================
SCHEMAPILE_TARGET_TABLES=1000
SCHEMAPILE_STRATEGY=random
SCHEMAPILE_SEED=42
SCHEMAPILE_MIN_TABLES=2
SCHEMAPILE_MAX_TABLES=100
SCHEMAPILE_MIN_FK_EDGES=1
SCHEMAPILE_REQUIRE_SELF_CONTAINED=true
SCHEMAPILE_REQUIRE_DATA=false

# Local cache for the produced slice JSON.
SCHEMAPILE_SLICE_CACHE=.cache/slice_random_1000.json

# Local cache for the candidate-table JSON the materializer and question
# generator both read.
SCHEMAPILE_CANDIDATE_CACHE=.cache/candidates_random_1000.json

# =============================================================================
# 3. Candidate selector filters
# Applied on top of the slice. The candidate JSON is what both the
# materializer and the LLM question generator consume.
# =============================================================================
SCHEMAPILE_CANDIDATE_MIN_TABLES=3
SCHEMAPILE_CANDIDATE_MAX_TABLES=20
SCHEMAPILE_CANDIDATE_MIN_FK_EDGES=2
SCHEMAPILE_CANDIDATE_REQUIRE_DATA=false
SCHEMAPILE_CANDIDATE_LIMIT=20

# =============================================================================
# 4. Databricks workspace + auth
# =============================================================================
DATABRICKS_PROFILE=<databricks-profile>
DATABRICKS_WAREHOUSE_ID=<warehouse-id>

# =============================================================================
# 5. Separate Unity Catalog for SchemaPile materialized tables
# Must not match the finance-genie catalog or any other project catalog.
# The bootstrap step refuses to run otherwise.
# =============================================================================
DBXCARTA_CATALOG=schemapile_lakehouse
SCHEMAPILE_META_SCHEMA=_meta
SCHEMAPILE_VOLUME=schemapile_volume

# Comma-separated list of UC schemas the materializer wrote. The materialize
# step writes this value into .env.generated; copy it back here once that file
# is produced or source .env.generated alongside .env.
DBXCARTA_SCHEMAS=

DATABRICKS_VOLUME_PATH=/Volumes/schemapile_lakehouse/_meta/schemapile_volume

DBXCARTA_SUMMARY_VOLUME=/Volumes/schemapile_lakehouse/_meta/schemapile_volume/dbxcarta/runs
DBXCARTA_SUMMARY_TABLE=schemapile_lakehouse._meta.dbxcarta_run_summary

# =============================================================================
# 6. Sample values and embeddings
# Defaults bias toward a smaller first run; flip values-embedding on after a
# clean offline pass.
# =============================================================================
DBXCARTA_INCLUDE_VALUES=true
DBXCARTA_SAMPLE_LIMIT=10
DBXCARTA_SAMPLE_CARDINALITY_THRESHOLD=50

DBXCARTA_INCLUDE_EMBEDDINGS_TABLES=true
DBXCARTA_INCLUDE_EMBEDDINGS_COLUMNS=true
DBXCARTA_INCLUDE_EMBEDDINGS_VALUES=false
DBXCARTA_INCLUDE_EMBEDDINGS_SCHEMAS=true
DBXCARTA_INCLUDE_EMBEDDINGS_DATABASES=false
DBXCARTA_INFER_SEMANTIC=true

DBXCARTA_EMBEDDING_ENDPOINT=databricks-gte-large-en
DBXCARTA_EMBEDDING_DIMENSION=1024
DBXCARTA_EMBEDDING_FAILURE_THRESHOLD=0.10

# =============================================================================
# 7. Question generator (LLM via Databricks Foundation Model API)
# =============================================================================
SCHEMAPILE_QUESTION_MODEL=databricks-meta-llama-3-3-70b-instruct
SCHEMAPILE_QUESTIONS_PER_SCHEMA=6
SCHEMAPILE_QUESTION_TEMPERATURE=0.2

# =============================================================================
# 8. Client evaluation arms
# =============================================================================
DBXCARTA_CLIENT_QUESTIONS=/Volumes/schemapile_lakehouse/_meta/schemapile_volume/dbxcarta/questions.json
DBXCARTA_CLIENT_ARMS=no_context,schema_dump,graph_rag
DBXCARTA_INJECT_CRITERIA=false

# =============================================================================
# 9. Neo4j secret scope (must match the dbxcarta core install)
# =============================================================================
DATABRICKS_SECRET_SCOPE=dbxcarta-neo4j
