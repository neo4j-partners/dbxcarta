# Local-demo .env for the Finance Genie example.
#
# Copy this file to `.env` in this same directory before running the local
# demo. The demo loads `.env` anchored to this directory and never inherits
# the parent dbxcarta repo's .env, so this file is the single source of
# truth for the local demo.
#
# The dbxcarta CLI (`ready`, `bootstrap`, `publish-wheels`, `submit-entrypoint ingest`)
# is a separate workflow run from the parent dbxcarta repo and uses that
# repo's .env, not this one. Its per-integration config is the committed,
# secret-free ./dbxcarta-overlay.env; edit that file, not this one, to change
# a CLI run. The two intentionally differ (this file targets the standalone
# local-demo catalog; the overlay targets the medallion catalogs).

# --- Operator credentials (fill these in) ---------------------------------

DATABRICKS_PROFILE=aws-partner-rk
DATABRICKS_WAREHOUSE_ID=
DBXCARTA_CHAT_ENDPOINT=databricks-claude-sonnet-4-6

NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=

# --- Standalone local-demo ops location -----------------------------------
# Ingest, embedding, value-sampling, and eval-client config live in the
# committed ./dbxcarta-overlay.env, not here. The local demo targets its own
# standalone catalog, separate from the overlay's medallion catalogs.

DBXCARTA_CATALOG=graph-enriched-lakehouse
DATABRICKS_VOLUME_PATH=/Volumes/graph-enriched-lakehouse/graph-enriched-schema/graph-enriched-volume

DBXCARTA_SUMMARY_VOLUME=/Volumes/graph-enriched-lakehouse/graph-enriched-schema/graph-enriched-volume/dbxcarta/runs
