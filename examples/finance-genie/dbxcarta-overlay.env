# dbxcarta CLI overlay for the Finance Genie medallion catalogs.
#
# Select it for any dbxcarta CLI command with:
#   uv run dbxcarta submit-entrypoint ingest \
#     --env-file examples/finance-genie/dbxcarta-overlay.env
# or export DBXCARTA_ENV_FILE to the same path.
#
# Overlay-only and secret-free: it carries only dbxcarta-scoped values
# and is layered over the shared base .env (Databricks infra + Neo4j
# secrets). No NEO4J_* or tokens belong here, so this file is committed.
# This is NOT the standalone local-demo config (see ./.env / ./.env.sample).

# Per-integration Neo4j secret scope (a scope NAME, not a secret). Overrides the
# base .env default so the ingest reads this example's own instance. Provision
# it from examples/finance-genie/.env with ./setup_secrets.sh.
# Operator tooling reads DATABRICKS_SECRET_SCOPE; the neocarta ingest wheel reads
# NEOCARTA_DATABRICKS_SECRET_SCOPE. Both name the same scope.
DATABRICKS_SECRET_SCOPE=dbxcarta-neo4j-finance-genie
NEOCARTA_DATABRICKS_SECRET_SCOPE=dbxcarta-neo4j-finance-genie

DBXCARTA_CATALOG=graph-enriched-finance-silver
# Each entry is catalog or catalog:layer. The :layer suffix drives the Table
# node `layer` property; the layer rides on the catalog so the two cannot drift.
DBXCARTA_CATALOGS=graph-enriched-finance-silver:silver,graph-enriched-finance-gold:gold
DATABRICKS_VOLUME_PATH=/Volumes/dbxcarta-catalog/finance_genie_ops/dbxcarta-ops
# `dbxcarta teardown` drops only the finance ops schema; the shared
# dbxcarta-catalog (upstream data catalogs are separate) is left intact.
DBXCARTA_TEARDOWN_TARGET=schema:dbxcarta-catalog.finance_genie_ops

# Durable run-summary Volume the client and materialize read (derivable, kept
# explicit). The run-summary TABLE is no longer configured: the core resolver
# derives it and the neocarta connector has no such field.
DBXCARTA_SUMMARY_VOLUME=/Volumes/dbxcarta-catalog/finance_genie_ops/dbxcarta-ops/dbxcarta/runs

# --- neocarta ingest contract (NEOCARTA_DATABRICKS_*) ---
# The neocarta connector wheel reads only NEOCARTA_DATABRICKS_* and ignores the
# operator/client keys above. catalog/catalogs/schemas mirror the dbxcarta keys.
NEOCARTA_DATABRICKS_CATALOG=graph-enriched-finance-silver
NEOCARTA_DATABRICKS_CATALOGS=graph-enriched-finance-silver:silver,graph-enriched-finance-gold:gold
NEOCARTA_DATABRICKS_SCHEMAS=graph-enriched-schema
# Value sampling. Set explicitly so the behavior is visible here instead of
# relying on neocarta's defaults. These match neocarta's defaults.
NEOCARTA_DATABRICKS_INCLUDE_VALUES=true
NEOCARTA_DATABRICKS_SAMPLE_LIMIT=10
NEOCARTA_DATABRICKS_SAMPLE_CARDINALITY_THRESHOLD=50
# Inline embeddings: embed nodes in-cluster during ingest. neocarta has no Value
# embedding. With any flag on, EMBEDDING_STAGING_VOLUME below is required.
NEOCARTA_DATABRICKS_INCLUDE_EMBEDDINGS_TABLES=true
NEOCARTA_DATABRICKS_INCLUDE_EMBEDDINGS_COLUMNS=true
NEOCARTA_DATABRICKS_INCLUDE_EMBEDDINGS_SCHEMAS=true
NEOCARTA_DATABRICKS_INCLUDE_EMBEDDINGS_DATABASES=true
# Inline embedding tuning. databricks-gte-large-en emits 1024-dim vectors.
NEOCARTA_DATABRICKS_EMBEDDING_ENDPOINT=databricks-gte-large-en
NEOCARTA_DATABRICKS_EMBEDDING_DIMENSION=1024
NEOCARTA_DATABRICKS_EMBEDDING_BATCH_TABLES=200
NEOCARTA_DATABRICKS_EMBEDDING_FAILURE_MAX=0
# Required transient staging subpath for each batch's ai_query materialization.
NEOCARTA_DATABRICKS_EMBEDDING_STAGING_VOLUME=/Volumes/dbxcarta-catalog/finance_genie_ops/dbxcarta-ops/dbxcarta/embed-staging
# Optional durable run-summary Volume so a detached cluster run leaves a report.
NEOCARTA_DATABRICKS_SUMMARY_VOLUME=/Volumes/dbxcarta-catalog/finance_genie_ops/dbxcarta-ops/dbxcarta/runs

# Local questions file the client reads directly. The client runs locally now
# (no cluster, no Volume), so this is a repo-relative path, not a /Volumes path.
DBXCARTA_CLIENT_QUESTIONS=examples/finance-genie/questions.json
DBXCARTA_CLIENT_ARMS=no_context,schema_dump,graph_rag
DBXCARTA_SCHEMA_DUMP_MAX_CHARS=50000
DBXCARTA_INJECT_CRITERIA=false
DBXCARTA_CLIENT_MAX_EXPANSION_TABLES=20
# Client query-time embedding endpoint. Pinned to match the ingest endpoint
# above so graph_rag embeds questions with the model that built the graph.
DBXCARTA_EMBEDDING_ENDPOINT=databricks-gte-large-en
