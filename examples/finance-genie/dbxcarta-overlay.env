# dbxcarta CLI overlay for the Finance Genie medallion catalogs.
#
# Select it for any dbxcarta CLI command with:
#   uv run dbxcarta submit-entrypoint ingest \
#     --env-file examples/finance-genie/dbxcarta-overlay.env
# or export DBXCARTA_ENV_FILE to the same path.
#
# Overlay-only and secret-free: it carries only dbxcarta-scoped values
# and is layered over the shared base .env (Databricks infra + Neo4j
# secrets). No NEO4J_* or tokens belong here, so this file is committed.
# This is NOT the standalone local-demo config (see ./.env / ./.env.sample).

# Per-integration Neo4j secret scope (a scope NAME, not a secret). Overrides the
# base .env default so the ingest reads this example's own instance. Provision
# it from examples/finance-genie/.env with ./setup_secrets.sh.
DATABRICKS_SECRET_SCOPE=dbxcarta-neo4j-finance-genie

DBXCARTA_CATALOG=graph-enriched-finance-silver
DBXCARTA_CATALOGS=graph-enriched-finance-bronze,graph-enriched-finance-silver,graph-enriched-finance-gold
DBXCARTA_LAYER_MAP=graph-enriched-finance-bronze:bronze,graph-enriched-finance-silver:silver,graph-enriched-finance-gold:gold
DBXCARTA_SCHEMAS=graph-enriched-schema
DATABRICKS_VOLUME_PATH=/Volumes/dbxcarta-catalog/finance_genie_ops/dbxcarta-ops

DBXCARTA_SUMMARY_VOLUME=/Volumes/dbxcarta-catalog/finance_genie_ops/dbxcarta-ops/dbxcarta/runs
DBXCARTA_SUMMARY_TABLE=dbxcarta-catalog.finance_genie_ops.dbxcarta_run_summary

DBXCARTA_INCLUDE_VALUES=true
DBXCARTA_SAMPLE_LIMIT=10
DBXCARTA_SAMPLE_CARDINALITY_THRESHOLD=50

DBXCARTA_INCLUDE_EMBEDDINGS_TABLES=true
DBXCARTA_INCLUDE_EMBEDDINGS_COLUMNS=true
DBXCARTA_INCLUDE_EMBEDDINGS_VALUES=true
DBXCARTA_INCLUDE_EMBEDDINGS_SCHEMAS=true
DBXCARTA_INCLUDE_EMBEDDINGS_DATABASES=true
DBXCARTA_EMBEDDING_FAILURE_MAX=0

DBXCARTA_CLIENT_QUESTIONS=/Volumes/dbxcarta-catalog/finance_genie_ops/dbxcarta-ops/dbxcarta/questions.json
DBXCARTA_CLIENT_ARMS=no_context,schema_dump,graph_rag
DBXCARTA_SCHEMA_DUMP_MAX_CHARS=50000
DBXCARTA_INJECT_CRITERIA=false
DBXCARTA_CLIENT_MAX_EXPANSION_TABLES=20
