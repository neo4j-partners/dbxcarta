# Overlay for submit_finance_genie.py — copy to submit_finance_genie.env.
# The populated submit_finance_genie.env is local-only and gitignored; do not
# commit it.
#
# This is a dbxcarta CLI overlay, layered over the repo-root base .env exactly
# like examples/finance-genie/dbxcarta-overlay.env. It carries only the
# per-integration values; the Databricks infra (DATABRICKS_PROFILE,
# DATABRICKS_CLUSTER_ID, DATABRICKS_WAREHOUSE_ID, DATABRICKS_WORKSPACE_DIR,
# DATABRICKS_COMPUTE_MODE) and NEOCARTA_WHEEL_SOURCE come from the base .env and
# must NOT be repeated here — an entry here wins over the base, so a stale value
# would silently override the real workspace infra.
#
# Secret-free: no NEO4J_* or tokens. The submit tool forwards these KEY=VALUE
# pairs to the cluster as job parameters, and the cluster reads the Neo4j
# credentials at runtime from the Databricks secret scope named below
# (NEOCARTA_DATABRICKS_SECRET_SCOPE), which must already be provisioned.

# --- per-integration ops plane ---
# Neo4j secret scope (a scope NAME, not a secret). Operator tooling reads
# DATABRICKS_SECRET_SCOPE; the neocarta ingest wheel reads
# NEOCARTA_DATABRICKS_SECRET_SCOPE. Both name the same scope.
DATABRICKS_SECRET_SCOPE=dbxcarta-neo4j-finance-genie
NEOCARTA_DATABRICKS_SECRET_SCOPE=dbxcarta-neo4j-finance-genie
# UC Volume root for staging the connector wheel and the bootstrap script.
DATABRICKS_VOLUME_PATH=/Volumes/dbxcarta-catalog/finance_genie_ops/dbxcarta-ops

# --- neocarta ingest contract (NEOCARTA_DATABRICKS_*) ---
# The connector wheel reads only these on the cluster. Pre-filled with the
# finance-genie values; adjust for your deployment.
NEOCARTA_DATABRICKS_CATALOG=graph-enriched-finance-silver
NEOCARTA_DATABRICKS_CATALOGS=graph-enriched-finance-silver:silver,graph-enriched-finance-gold:gold
NEOCARTA_DATABRICKS_SCHEMAS=graph-enriched-schema
# Value sampling.
NEOCARTA_DATABRICKS_INCLUDE_VALUES=true
NEOCARTA_DATABRICKS_SAMPLE_LIMIT=10
NEOCARTA_DATABRICKS_SAMPLE_CARDINALITY_THRESHOLD=50
# Inline embeddings: embed nodes in-cluster during ingest.
NEOCARTA_DATABRICKS_INCLUDE_EMBEDDINGS_TABLES=true
NEOCARTA_DATABRICKS_INCLUDE_EMBEDDINGS_COLUMNS=true
NEOCARTA_DATABRICKS_INCLUDE_EMBEDDINGS_SCHEMAS=true
NEOCARTA_DATABRICKS_INCLUDE_EMBEDDINGS_DATABASES=true
# Workspace-native embedding endpoint; databricks-gte-large-en emits 1024-dim
# vectors and needs no external-model registration. Matches the finance-genie
# overlay so the graph embeds with the same model the client queries with.
NEOCARTA_DATABRICKS_EMBEDDING_ENDPOINT=databricks-gte-large-en
NEOCARTA_DATABRICKS_EMBEDDING_DIMENSION=1024
NEOCARTA_DATABRICKS_EMBEDDING_BATCH_TABLES=200
NEOCARTA_DATABRICKS_EMBEDDING_FAILURE_MAX=0
# Required transient staging subpath for each batch's ai_query materialization.
NEOCARTA_DATABRICKS_EMBEDDING_STAGING_VOLUME=/Volumes/dbxcarta-catalog/finance_genie_ops/dbxcarta-ops/dbxcarta/embed-staging
# Optional durable run-summary Volume so a detached cluster run leaves a report.
NEOCARTA_DATABRICKS_SUMMARY_VOLUME=/Volumes/dbxcarta-catalog/finance_genie_ops/dbxcarta-ops/dbxcarta/runs
