# dbxcarta CLI overlay for the dense-schema (Phase G) evaluation fixture.
#
# Select it for any dbxcarta CLI command with:
#   uv run dbxcarta submit-entrypoint ingest \
#     --env-file examples/dense-schema/dbxcarta-overlay.env
# or export DBXCARTA_ENV_FILE to the same path.
#
# Overlay-only and secret-free: it carries only dbxcarta-scoped values
# and is layered over the shared base .env (Databricks infra + Neo4j
# secrets). No NEO4J_* or tokens belong here, so this file is committed.
# This is NOT the standalone fixture config (see ./.env / ./.env.sample).

# Per-integration Neo4j secret scope (a scope NAME, not a secret). Overrides the
# base default so the ingest reads this example's own instance. Provision it
# from examples/dense-schema/.env with ./setup_secrets.sh (add NEO4J_* there).
# Operator tooling reads DATABRICKS_SECRET_SCOPE; the neocarta ingest wheel reads
# NEOCARTA_DATABRICKS_SECRET_SCOPE. Both name the same scope.
DATABRICKS_SECRET_SCOPE=dbxcarta-neo4j-dense-schema
NEOCARTA_DATABRICKS_SECRET_SCOPE=dbxcarta-neo4j-dense-schema

# dense owns its own data catalog (dense-schema-example), holding only the
# dense_500 fixture schema. Its ops plane (wheels volume, run summary, uploaded
# questions) lives in dbxcarta-catalog.dense-ops, mirroring finance-genie and
# schemapile, so the data catalog stays pure data.
DBXCARTA_CATALOG=dense-schema-example
# The full ingest catalog list. dense has one data catalog and no medallion
# layer, so it lists that single catalog with no `:layer` suffix. Listed
# explicitly so all three examples express their catalog set the same way.
DBXCARTA_CATALOGS=dense-schema-example
DATABRICKS_VOLUME_PATH=/Volumes/dbxcarta-catalog/dense-ops/dbxcarta-ops
# Teardown removes dense's full footprint: the first target drops the data
# catalog (with dense_500 inside), the second drops dense's ops schema in the
# shared dbxcarta-catalog. The shared catalog itself is never dropped.
DBXCARTA_TEARDOWN_TARGET=catalog:dense-schema-example,schema:dbxcarta-catalog.dense-ops

# Durable run-summary Volume the client and materialize read (derivable, kept
# explicit). The run-summary TABLE is no longer configured: the core resolver
# derives it and the neocarta connector has no such field.
DBXCARTA_SUMMARY_VOLUME=/Volumes/dbxcarta-catalog/dense-ops/dbxcarta-ops/dbxcarta/runs

# --- neocarta ingest contract (NEOCARTA_DATABRICKS_*) ---
# The neocarta connector wheel reads only NEOCARTA_DATABRICKS_* and ignores the
# operator/client keys above. catalog/catalogs/schemas mirror the dbxcarta keys.
NEOCARTA_DATABRICKS_CATALOG=dense-schema-example
NEOCARTA_DATABRICKS_CATALOGS=dense-schema-example
# Must match the schema the committed blueprint declares (uc_schema=dense_500).
NEOCARTA_DATABRICKS_SCHEMAS=dense_500
# Inline embeddings: embed nodes in-cluster during ingest. neocarta has no Value
# embedding. With any flag on, EMBEDDING_STAGING_VOLUME below is required.
NEOCARTA_DATABRICKS_INCLUDE_EMBEDDINGS_TABLES=true
NEOCARTA_DATABRICKS_INCLUDE_EMBEDDINGS_COLUMNS=true
NEOCARTA_DATABRICKS_INCLUDE_EMBEDDINGS_SCHEMAS=true
NEOCARTA_DATABRICKS_INCLUDE_EMBEDDINGS_DATABASES=false
# Inline embedding tuning. databricks-gte-large-en emits 1024-dim vectors.
NEOCARTA_DATABRICKS_EMBEDDING_ENDPOINT=databricks-gte-large-en
NEOCARTA_DATABRICKS_EMBEDDING_DIMENSION=1024
NEOCARTA_DATABRICKS_EMBEDDING_BATCH_TABLES=200
NEOCARTA_DATABRICKS_EMBEDDING_FAILURE_MAX=0
# Required transient staging subpath for each batch's ai_query materialization.
NEOCARTA_DATABRICKS_EMBEDDING_STAGING_VOLUME=/Volumes/dbxcarta-catalog/dense-ops/dbxcarta-ops/dbxcarta/embed-staging
# Optional durable run-summary Volume so a detached cluster run leaves a report.
NEOCARTA_DATABRICKS_SUMMARY_VOLUME=/Volumes/dbxcarta-catalog/dense-ops/dbxcarta-ops/dbxcarta/runs

DBXCARTA_CLIENT_QUESTIONS=/Volumes/dbxcarta-catalog/dense-ops/dbxcarta-ops/dbxcarta/dense_questions.json
# Post-ingest smoke check: evaluate only the first 5 questions to confirm the
# FK fix flows end to end. Remove (or set to 0) to run the full question set.
DBXCARTA_CLIENT_MAX_QUESTIONS=5
DBXCARTA_CLIENT_ARMS=no_context,schema_dump,graph_rag
DBXCARTA_INJECT_CRITERIA=true
DBXCARTA_SCHEMA_DUMP_MAX_CHARS=50000
