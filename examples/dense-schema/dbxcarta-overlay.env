# dbxcarta CLI overlay for the dense-schema (Phase G) evaluation fixture.
#
# Select it for any dbxcarta CLI command with:
#   uv run dbxcarta submit-entrypoint ingest \
#     --env-file examples/dense-schema/dbxcarta-overlay.env
# or export DBXCARTA_ENV_FILE to the same path.
#
# Overlay-only and secret-free: it carries only dbxcarta-scoped values
# and is layered over the shared base .env (Databricks infra + Neo4j
# secrets). No NEO4J_* or tokens belong here, so this file is committed.
# This is NOT the standalone fixture config (see ./.env / ./.env.sample).

# Per-integration Neo4j secret scope (a scope NAME, not a secret). Overrides the
# base default so the ingest reads this example's own instance. Provision it
# from examples/dense-schema/.env with ./setup_secrets.sh (add NEO4J_* there).
DATABRICKS_SECRET_SCOPE=dbxcarta-neo4j-dense-schema

# Reuses the schemapile lakehouse catalog and volume; the dense fixture lives in
# its own schema (dense_1000).
DBXCARTA_CATALOG=dense-schema_example
DBXCARTA_SCHEMAS=dense_1000
DATABRICKS_VOLUME_PATH=/Volumes/dense-schema_example/_meta/schemapile_volume
# `dbxcarta-submit teardown` drops only the dense data schema; the shared
# catalog, _meta schema, and volume are left for schemapile.
DBXCARTA_TEARDOWN_TARGET=schema:dense-schema_example.dense_1000

DBXCARTA_SUMMARY_VOLUME=/Volumes/dense-schema_example/_meta/schemapile_volume/dbxcarta/runs
DBXCARTA_SUMMARY_TABLE=dense-schema_example._meta.dbxcarta_run_summary

DBXCARTA_INCLUDE_VALUES=true
DBXCARTA_SAMPLE_LIMIT=10
DBXCARTA_SAMPLE_CARDINALITY_THRESHOLD=50

DBXCARTA_INCLUDE_EMBEDDINGS_TABLES=true
DBXCARTA_INCLUDE_EMBEDDINGS_COLUMNS=true
DBXCARTA_INCLUDE_EMBEDDINGS_VALUES=false
DBXCARTA_INCLUDE_EMBEDDINGS_SCHEMAS=true
DBXCARTA_INCLUDE_EMBEDDINGS_DATABASES=false
DBXCARTA_EMBEDDING_ENDPOINT=databricks-gte-large-en
DBXCARTA_EMBEDDING_DIMENSION=1024
DBXCARTA_EMBEDDING_FAILURE_MAX=0

DBXCARTA_CLIENT_QUESTIONS=/Volumes/dense-schema_example/_meta/schemapile_volume/dbxcarta/dense_questions.json
DBXCARTA_CLIENT_ARMS=no_context,schema_dump,graph_rag
DBXCARTA_INJECT_CRITERIA=true
DBXCARTA_SCHEMA_DUMP_MAX_CHARS=50000
