# Dense-schema Phase G evaluation fixture
# Copy to .env and fill in the values

# Databricks workspace. dense owns its own data catalog (dense-schema-example);
# its ops plane lives in dbxcarta-catalog.dense-ops, separate from the data.
DATABRICKS_PROFILE=aws-partner-rk
DBXCARTA_CATALOG=dense-schema-example
DATABRICKS_WAREHOUSE_ID=

# Ops plane, separate from the data catalog above. Mirrors finance-genie and
# schemapile's dbxcarta-catalog.<example>_ops layout.
DATABRICKS_VOLUME_PATH=/Volumes/dbxcarta-catalog/dense-ops/dbxcarta-ops
DBXCARTA_SUMMARY_VOLUME=/Volumes/dbxcarta-catalog/dense-ops/dbxcarta-ops/dbxcarta/runs

# Dense-schema generation parameters
DENSE_TABLE_COUNT=500
DENSE_SCHEMA_NAME=dense_500
DENSE_SEED=42

# Question generation
DENSE_QUESTION_MODEL=databricks-meta-llama-3-3-70b-instruct
DENSE_QUESTIONS_TARGET=60
DENSE_QUESTIONS_PER_BATCH=3
DENSE_QUESTION_TEMPERATURE=0.2
