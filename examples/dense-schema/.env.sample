# Dense-schema Phase G evaluation fixture
# Copy to .env and fill in the values

# Databricks workspace — uses the schemapile catalog and volume
DATABRICKS_PROFILE=azure-rk-knight
DBXCARTA_CATALOG=schemapile_lakehouse
SCHEMAPILE_META_SCHEMA=_meta
SCHEMAPILE_VOLUME=schemapile_volume
DATABRICKS_WAREHOUSE_ID=

# Dense-schema generation parameters
DENSE_TABLE_COUNT=500
DENSE_SCHEMA_NAME=dense_500
DENSE_SEED=42

# Question generation
DENSE_QUESTION_MODEL=databricks-meta-llama-3-3-70b-instruct
DENSE_QUESTIONS_TARGET=60
DENSE_QUESTIONS_PER_BATCH=3
DENSE_QUESTION_TEMPERATURE=0.2

# dbxcarta client evaluation
DBXCARTA_SCHEMA_DUMP_MAX_CHARS=50000
DBXCARTA_CLIENT_MAX_EXPANSION_TABLES=15
