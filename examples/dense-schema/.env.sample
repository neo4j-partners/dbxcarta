# Dense-schema example: local-only config for the standalone tooling.
# Copy to .env and fill in the values. The populated .env is local-only.
#
# This file holds exactly two things and nothing else:
#   - the NEO4J_* credentials for this integration's Neo4j instance, and
#   - the DENSE_* knobs that only this example's question generator reads.
#
# Everything shared or per-integration lives elsewhere and must not be copied
# here (the one-key-one-file rule):
#   - shared infra (DATABRICKS_PROFILE, DATABRICKS_WAREHOUSE_ID, endpoints) is in
#     the repo-root base .env;
#   - per-integration config (DBXCARTA_CATALOG, DATABRICKS_VOLUME_PATH,
#     DATABRICKS_SECRET_SCOPE) is in the committed ./dbxcarta-overlay.env.
# The connected generator loads all three layers (overlay + base + this file).
#
# NEO4J_* are consumed two ways:
#   - setup_secrets.sh reads them to provision the Databricks secret scope named
#     in ./dbxcarta-overlay.env (pass --profile, since this file no longer sets
#     DATABRICKS_PROFILE);
#   - off-cluster, the generator/client read them straight from this file.

# Dense-schema generation parameters
DENSE_TABLE_COUNT=500
DENSE_SCHEMA_NAME=dense_500
DENSE_SEED=42

# Question generation
DENSE_QUESTION_MODEL=databricks-meta-llama-3-3-70b-instruct
DENSE_QUESTIONS_TARGET=60
DENSE_QUESTIONS_PER_BATCH=3
DENSE_QUESTION_TEMPERATURE=0.2

# Neo4j secrets
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
