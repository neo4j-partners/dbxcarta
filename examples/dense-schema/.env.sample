# Dense-schema Phase G evaluation fixture
# Copy to .env and fill in the values

# Databricks workspace. dense owns its own data catalog (dense-schema-example);
# its ops plane lives in dbxcarta-catalog.dense-ops, separate from the data.
DATABRICKS_PROFILE=aws-partner-rk
DBXCARTA_CATALOG=dense-schema-example
DATABRICKS_WAREHOUSE_ID=

# Ops plane, separate from the data catalog above. Mirrors finance-genie and
# schemapile's dbxcarta-catalog.<example>_ops layout. The standalone generator
# derives its run-summary path from this volume; the CLI run-summary location
# is configured only in dbxcarta-overlay.env.
DATABRICKS_VOLUME_PATH=/Volumes/dbxcarta-catalog/dense-ops/dbxcarta-ops

# Dense-schema generation parameters
DENSE_TABLE_COUNT=500
DENSE_SCHEMA_NAME=dense_500
DENSE_SEED=42

# Question generation
DENSE_QUESTION_MODEL=databricks-meta-llama-3-3-70b-instruct
DENSE_QUESTIONS_TARGET=60
DENSE_QUESTIONS_PER_BATCH=3
DENSE_QUESTION_TEMPERATURE=0.2

# Databricks secret scope holding the NEO4J_* secrets below. Must match this
# example's dbxcarta-overlay.env. setup_secrets.sh reads the scope name from the
# overlay, not from here; this entry keeps the host .env consistent with the
# other examples and is used by any client (ClientSettings) run from here.
DATABRICKS_SECRET_SCOPE=dbxcarta-neo4j-dense-schema

# Neo4j secrets. setup_secrets.sh reads these and writes them into the
# Databricks secret scope named in ./dbxcarta-overlay.env. The local client
# falls back to these same values from the environment off-cluster.
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
