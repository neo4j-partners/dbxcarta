# =============================================================================
# Databricks workspace connection
# References a profile in ~/.databrickscfg
# =============================================================================
DATABRICKS_PROFILE=<databricks-profile>

# =============================================================================
# Databricks compute and workspace
# =============================================================================
DATABRICKS_COMPUTE_MODE=cluster
DATABRICKS_CLUSTER_ID=<cluster-id>
DATABRICKS_WORKSPACE_DIR=/Users/<user>@<domain>/dbxcarta
DATABRICKS_VOLUME_PATH=/Volumes/<catalog-name>/dbxcarta
DATABRICKS_SECRET_SCOPE=dbxcarta-neo4j
DATABRICKS_WAREHOUSE_ID=<warehouse-id>

# =============================================================================
# Job dispatch — selects which entry point runs in run_dbxcarta.py
# Values: schema | sample | embeddings
# =============================================================================
DBXCARTA_JOB=schema

# =============================================================================
# Target Unity Catalog
# =============================================================================
DBXCARTA_CATALOG=<catalog-name>
DBXCARTA_SCHEMAS=                    # empty = all schemas; comma-separated to filter

# =============================================================================
# Run summary destinations
# The job creates both on first run if absent
# =============================================================================
DBXCARTA_SUMMARY_VOLUME=/Volumes/<catalog-name>/dbxcarta/runs
DBXCARTA_SUMMARY_TABLE=<catalog-name>.dbxcarta.run_summary

# =============================================================================
# Phase 2 — Sample values
# =============================================================================
DBXCARTA_SAMPLE_LIMIT=10
DBXCARTA_SAMPLE_CARDINALITY_THRESHOLD=50

# =============================================================================
# Phase 3 — Embeddings
# =============================================================================
DBXCARTA_EMBEDDING_ENDPOINT=databricks-bge-large-en
DBXCARTA_EMBEDDING_BATCH_SIZE=128

# =============================================================================
# Neo4j credentials — pushed to the Databricks secret scope by setup_secrets.sh
# Never commit the populated .env file.
# =============================================================================
NEO4J_URI=neo4j+s://<host>:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=<password>
